// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  category  String   @default("Berita Dewan")
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model Berita {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String?
  imageUrl    String?
  category    String   @default("Berita Dewan")
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("beritas")
}

model MasaJabatan {
  id          String     @id @default(cuid())
  periode     String     @unique  // e.g. "2024-2029"
  tahunMulai  Int
  tahunSelesai Int
  isAktif     Boolean    @default(false)
  keterangan  String?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  pimpinan    Pimpinan[]

  @@map("masa_jabatan")
}

model Pimpinan {
  id            String       @id @default(cuid())
  name          String
  position      String
  faction       String?
  period        String       @default("2024-2029")
  masaJabatanId String?
  masaJabatan   MasaJabatan? @relation(fields: [masaJabatanId], references: [id], onDelete: SetNull)
  isPast        Boolean      @default(false)
  imageUrl      String?
  bio           String?
  order         Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("pimpinan")
}

model Sekretariat {
  id        String   @id @default(cuid())
  visi      String?
  misi      String?
  tugas     String?
  fungsi    String?  // JSON array stored as text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sekretariat")
}

model AnggotaSekretariat {
  id           String   @id @default(cuid())
  name         String
  position     String
  unit         String?
  imageUrl     String?
  isSekretaris Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("anggota_sekretariat")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}
