# Supabase PostgreSQL Connection String (pakai Transaction Pooler dari Supabase dashboard)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Direct URL (untuk Prisma migrations)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Supabase API
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_KEY="[SERVICE_ROLE_KEY]"

# Storage Bucket Name (buat bucket ini di Supabase Storage dashboard)
STORAGE_BUCKET="dprd-media"

# JWT Secret (ubah dengan string random yang panjang)
JWT_SECRET="dprd-sumbawa-barat-secret-key-2025"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# Default Admin (untuk seed pertama kali)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ============ YouTube Data API v3 ============
# Dapatkan API key dari Google Cloud Console:
# 1. Buka https://console.cloud.google.com
# 2. Buat project baru atau pilih yang sudah ada
# 3. Enable "YouTube Data API v3"
# 4. Buat credentials → API Key
YOUTUBE_API_KEY="AIzaSyA9nmTsJqLUQN2Q2EPbg3S6vRaMMMQZOl4"
# Channel ID DPRD Sumbawa Barat (ambil dari URL channel YouTube)
YOUTUBE_CHANNEL_ID="UChiJPkWLvb3612aj4U3JwHg"

# ============ Instagram Graph API ============
# Untuk mendapatkan token:
# 1. Buat Facebook App di https://developers.facebook.com
# 2. Tambahkan product "Instagram Basic Display" atau "Instagram Graph API"
# 3. Generate long-lived access token
# 4. User ID bisa didapat dari endpoint /me?fields=id
INSTAGRAM_ACCESS_TOKEN="YOUR_INSTAGRAM_ACCESS_TOKEN"
INSTAGRAM_USER_ID="YOUR_INSTAGRAM_USER_ID"
